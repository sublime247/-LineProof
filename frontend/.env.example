# LineProof Frontend – environment variables
# Copy this file to .env.local and fill in real values before starting the app.

# Vite exposes VITE_* variables to the browser bundle.

# Backend API base URL
VITE_API_BASE_URL=http://localhost:4000/api

# Stellar network passphrase
VITE_STELLAR_NETWORK=Test SDF Network ; September 2015

# Soroban RPC endpoint
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed factory contract address
VITE_FACTORY_CONTRACT_ID=

# Enable Freighter wallet integration (true | false)
VITE_ENABLE_FREIGHTER=true
