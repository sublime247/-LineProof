# LineProof Backend – environment variables
# Copy this file to .env and fill in real values before starting the server.

# Express server port (default: 4000)
PORT=4000

# Node environment: development | test | production
NODE_ENV=development

# Friendly network label used by legacy read adapters.
STELLAR_NETWORK=TESTNET

# Exact Stellar network passphrase used to sign and simulate Soroban transactions.
# Required when any contract ID is configured.
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint for the selected network.
# Used to read authoritative on-chain state when contract IDs are configured
# (see ContractAdapter). Reads require a Soroban RPC (not Horizon) endpoint.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Operator secret key used only for write operations. If omitted in configured
# mode, reads remain enabled and writes return HTTP 503; never commit a real key.
OPERATOR_SECRET_KEY=

# ---------------------------------------------------------------------------
# Persistence (issue #4)
# ---------------------------------------------------------------------------
# PostgreSQL connection string. Leave EMPTY to use the in-memory adapter
# (default: state is ephemeral and wiped on restart — fine for local/dev/tests).
# Set it to select the durable PostgresAdapter. Apply the migrations in
# backend/src/db/migrations/ before enabling this.
#   e.g. postgres://user:password@localhost:5432/lineproof
DATABASE_URL=

# ---------------------------------------------------------------------------
# Deployed contract addresses — populate after running `make deploy-localnet`.
# Leave every ID empty for mock mode. Once any ID is set, the enrollment,
# escrow, and queue-factory IDs plus RPC URL and network passphrase are required.
# GET routes prefer chain state and fall back with X-Data-Source: mock.
# Canonical names (issue #4); the LINEPROOF_-prefixed aliases below still work.
# ---------------------------------------------------------------------------
QUEUE_FACTORY_CONTRACT_ID=
QUEUE_CONTRACT_ID=
ENROLLMENT_CONTRACT_ID=
IDENTITY_CONTRACT_ID=
ESCROW_CONTRACT_ID=

# Legacy aliases (kept for backward compatibility; canonical names take precedence)
LINEPROOF_FACTORY_CONTRACT_ID=
LINEPROOF_QUEUE_CONTRACT_ID=
LINEPROOF_ENROLLMENT_CONTRACT_ID=
LINEPROOF_IDENTITY_CONTRACT_ID=
LINEPROOF_ESCROW_CONTRACT_ID=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Log level: debug | info | warn | error
LOG_LEVEL=info
